__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
venv/
env/
.venv/

# PyInstaller 构建输出
build/
dist/
*.spec.bak

# IDE
.vscode/
.idea/
*.swp
*.swo

# 操作系统
.DS_Store
Thumbs.db

# 知识库运行时数据（大型文件）
knowledge_base/vector_db/
knowledge_base/cache/
!knowledge_base/vector_db/.gitkeep
!knowledge_base/cache/.gitkeep

# 测试数据
*.log
